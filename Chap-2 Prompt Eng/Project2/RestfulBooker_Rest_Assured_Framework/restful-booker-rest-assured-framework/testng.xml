<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="RestfulBookerSuite" parallel="classes" thread-count="4">

    <!-- Run only the smoke subset with: mvn test -Dgroups=smoke -->
    <!-- Run only negative/boundary with: mvn test -Dgroups=negative,boundary -->
    <test name="Regression">
        <classes>
            <class name="com.restfulbooker.tests.AuthTests" />
            <class name="com.restfulbooker.tests.PingTests" />
            <class name="com.restfulbooker.tests.GetBookingIdsTests" />
            <class name="com.restfulbooker.tests.GetBookingTests" />
            <class name="com.restfulbooker.tests.CreateBookingTests" />
            <class name="com.restfulbooker.tests.UpdateBookingTests" />
            <class name="com.restfulbooker.tests.PartialUpdateBookingTests" />
            <class name="com.restfulbooker.tests.DeleteBookingTests" />
        </classes>
    </test>

</suite>
